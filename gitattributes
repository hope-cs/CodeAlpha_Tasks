# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare common file types
*.py    text eol=lf
*.ipynb text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.csv   text eol=lf

# Binary files — do not modify
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
